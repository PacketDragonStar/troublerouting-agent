# =====================================================
# 网络排障多智能体系统 环境变量配置（模板）
# =====================================================
# 复制此文件为 .env 并修改实际值

# LLM API 配置
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_FALLBACK_MODEL=gpt-4o-mini
LLM_LOCAL_MODEL=deepseek-chat

# Redis 配置（GroupChat 状态持久化）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ChromaDB 配置（向量案例库）
CHROMA_HOST=localhost
CHROMA_PORT=8001

# 状态存储后端（sqlite 或 mysql）
STATE_BACKEND=sqlite

# SQLite 配置（STATE_BACKEND=sqlite 时使用）
SQLITE_PATH=data/troublerouting.db

# MySQL 配置（STATE_BACKEND=mysql 时使用）
# 使用 MySQL 前需要先手动建库：CREATE DATABASE troublerouting DEFAULT CHARSET utf8mb4;
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=your_mysql_password
MYSQL_DB=troublerouting

# 日志配置
LOG_LEVEL=INFO
LOG_PATH=logs/

# 网络设备默认超时（秒）
DEVICE_CONNECT_TIMEOUT=5
DEVICE_COMMAND_TIMEOUT=15